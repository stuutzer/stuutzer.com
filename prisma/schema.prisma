generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String         @unique
  title         String
  client        String?
  collaborators String[]
  category      String
  date          DateTime
  description   String
  images        ProjectImage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([date])
  @@index([category])
}

model ProjectImage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  src       String
  alt       String
  width     Int?
  height    Int?
  order     Int     @default(0)
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
